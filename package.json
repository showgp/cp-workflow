{
  "name": "cp-workflow",
  "version": "1.0.0",
  "description": "从 Excel / CSV 批量生成 Figma 模板页面的插件",
  "main": "code.js",
  "scripts": {
    "build:sandbox": "node scripts/build-sandbox.mjs",
    "build:ui": "node scripts/build-ui.mjs",
    "build": "npm run build:sandbox && npm run build:ui",
    "watch:sandbox": "node scripts/build-sandbox.mjs --watch",
    "watch:ui": "node scripts/build-ui.mjs --watch",
    "dev": "npm run build && concurrently \"npm:watch:sandbox\" \"npm:watch:ui\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.sandbox.json --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "clean": "rm -f code.js ui.html",
    "package": "node scripts/package.mjs"
  },
  "author": "cp-workflow contributors",
  "license": "MIT",
  "dependencies": {
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
