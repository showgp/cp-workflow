{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["es2017"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "rootDir": "./src",
    "typeRoots": [
      "./node_modules/@figma"
    ],
    "types": ["plugin-typings"],
    "removeComments": true,
    "sourceMap": false
  },
  "include": ["src/sandbox/**/*.ts", "src/shared/**/*.ts"]
}
